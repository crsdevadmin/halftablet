# Copy this file to .env.local and fill in your values

# OpenAI — get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# App URL (change for production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# NextAuth (Phase 2) — generate a secret with: npx auth secret
# or use any long random string in dev
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-string

# PostgreSQL (Phase 2) — Prisma also reads this from a plain .env file
# Local:  postgresql://postgres:YOUR_PASSWORD@localhost:5432/drmed
# AWS RDS: postgresql://postgres:YOUR_PASSWORD@YOUR-ENDPOINT.ap-south-1.rds.amazonaws.com:5432/drmed?sslmode=require
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/drmed

# AWS (cloud storage for prescriptions — leave unset to store files locally)
AWS_REGION=ap-south-1
AWS_S3_BUCKET=
# Only needed on your local machine; on Amplify use the service role instead
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Razorpay (Phase 3)
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_...
